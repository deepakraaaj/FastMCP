TAG_FASTMCP_ENVIRONMENT=development
TAG_FASTMCP_HOST=127.0.0.1
TAG_FASTMCP_PORT=8001
TAG_FASTMCP_TRANSPORT=streamable-http
TAG_FASTMCP_PATH=/mcp
TAG_FASTMCP_STATELESS_HTTP=true
TAG_FASTMCP_ALLOW_MUTATIONS=false
TAG_FASTMCP_REQUIRE_SELECT_WHERE=true
TAG_FASTMCP_DEFAULT_ROW_LIMIT=50
TAG_FASTMCP_SESSION_STORE_BACKEND=memory
TAG_FASTMCP_IDEMPOTENCY_STORE_BACKEND=memory
TAG_FASTMCP_VALKEY_URL=valkey://127.0.0.1:6379/0
TAG_FASTMCP_VALKEY_KEY_PREFIX=tag_fastmcp
TAG_FASTMCP_SESSION_TTL_SECONDS=86400
TAG_FASTMCP_IDEMPOTENCY_TTL_SECONDS=86400
TAG_FASTMCP_DATABASE_URL=sqlite+aiosqlite:///data/tag_fastmcp.sqlite3
TAG_FASTMCP_CONTROL_PLANE_DATABASE_URL=
TAG_FASTMCP_APPS_CONFIG_PATH=apps.yaml
# For localhost DB work, switch this to:
# TAG_FASTMCP_APPS_CONFIG_PATH=apps.local.yaml
TAG_FASTMCP_DEFAULT_CHAT_APP_ID=
TAG_FASTMCP_LLM_BASE_URL=http://127.0.0.1:8000/v1
TAG_FASTMCP_LLM_MODEL=Qwen-Opt-v1.5
